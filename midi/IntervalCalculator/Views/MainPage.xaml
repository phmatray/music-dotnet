<Page
    x:Class="IntervalCalculator.Views.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:IntervalCalculator"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:converters="using:IntervalCalculator.Views.Converters"
    mc:Ignorable="d"
    RequestedTheme="Light"
    Loaded="IntervalCalculatorPage_OnLoaded">

    <Page.Resources>
        <!-- Control templates -->
        <Style TargetType="RadioButton" x:Key="ButtonRadioButtonStyle">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Gray"/>
            <Setter Property="Foreground" Value="DimGray"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="VerticalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="BorderThickness" Value="4"/>
            <Setter Property="FontSize" Value="22px"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="MinWidth" Value="0"></Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">

                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal"/>
                                    <VisualState x:Name="PointerOver">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="(UIElement.Visibility)" Storyboard.TargetName="HoverBackground">
                                                <DiscreteObjectKeyFrame KeyTime="0">
                                                    <DiscreteObjectKeyFrame.Value>
                                                        <Visibility>Visible</Visibility>
                                                    </DiscreteObjectKeyFrame.Value>
                                                </DiscreteObjectKeyFrame>
                                            </ObjectAnimationUsingKeyFrames>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="(UIElement.Visibility)" Storyboard.TargetName="CheckedHoverBackground">
                                                <DiscreteObjectKeyFrame KeyTime="0">
                                                    <DiscreteObjectKeyFrame.Value>
                                                        <Visibility>Visible</Visibility>
                                                    </DiscreteObjectKeyFrame.Value>
                                                </DiscreteObjectKeyFrame>
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="(UIElement.Visibility)" Storyboard.TargetName="PressedBackground">
                                                <DiscreteObjectKeyFrame KeyTime="0">
                                                    <DiscreteObjectKeyFrame.Value>
                                                        <Visibility>Visible</Visibility>
                                                    </DiscreteObjectKeyFrame.Value>
                                                </DiscreteObjectKeyFrame>
                                            </ObjectAnimationUsingKeyFrames>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="(UIElement.Visibility)" Storyboard.TargetName="CheckedPressedBackground">
                                                <DiscreteObjectKeyFrame KeyTime="0">
                                                    <DiscreteObjectKeyFrame.Value>
                                                        <Visibility>Visible</Visibility>
                                                    </DiscreteObjectKeyFrame.Value>
                                                </DiscreteObjectKeyFrame>
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Disabled">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ContentPresenter" Storyboard.TargetProperty="Foreground">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource RadioButtonContentDisabledForegroundThemeBrush}" />
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                </VisualStateGroup>
                                <VisualStateGroup x:Name="CheckStates">
                                    <VisualState x:Name="Checked">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="(UIElement.Visibility)" Storyboard.TargetName="CheckedBackground">
                                                <DiscreteObjectKeyFrame KeyTime="0">
                                                    <DiscreteObjectKeyFrame.Value>
                                                        <Visibility>Visible</Visibility>
                                                    </DiscreteObjectKeyFrame.Value>
                                                </DiscreteObjectKeyFrame>
                                            </ObjectAnimationUsingKeyFrames>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ContentPresenter" Storyboard.TargetProperty="Foreground">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource White}" />
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Unchecked" />
                                    <VisualState x:Name="Indeterminate" />
                                </VisualStateGroup>
                                <VisualStateGroup x:Name="FocusStates">
                                    <VisualState x:Name="Focused">
                                        <Storyboard>
                                            <DoubleAnimation Duration="0" Storyboard.TargetName="FocusVisualWhite" Storyboard.TargetProperty="Opacity" To="1" />
                                            <DoubleAnimation Duration="0" Storyboard.TargetName="FocusVisualBlack" Storyboard.TargetProperty="Opacity" To="1" />
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Unfocused" />
                                    <VisualState x:Name="PointerFocused" />
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>


                            <Grid>
                                <Grid.Resources>
                                    <Style TargetType="Rectangle" x:Name="FocusVisual">
                                        <Setter Property="Opacity" Value="0" />
                                        <Setter Property="StrokeDashArray" Value="1,1" />
                                        <Setter Property="StrokeEndLineCap" Value="Square" />
                                    </Style>
                                </Grid.Resources>


                                <!-- background -->
                                <Grid x:Name="NotCheckedBackground" Grid.ColumnSpan="4">
                                    <Rectangle x:Name="HoverBackground" Visibility="Collapsed" Fill="{TemplateBinding BorderBrush}" Opacity="0.25"/>
                                    <Rectangle x:Name="PressedBackground" Visibility="Collapsed" Fill="{TemplateBinding BorderBrush}" Opacity="0.50"/>
                                </Grid>
                                <Grid x:Name="CheckedBackground" Grid.ColumnSpan="4" Visibility="Collapsed" Background="{TemplateBinding BorderBrush}" Opacity="0.50">
                                    <Rectangle x:Name="CheckedHoverBackground" Visibility="Collapsed" Fill="{TemplateBinding BorderBrush}" Opacity="0.75"/>
                                    <Rectangle x:Name="CheckedPressedBackground" Visibility="Collapsed" Fill="{TemplateBinding BorderBrush}" Opacity="1.00"/>
                                </Grid>


                                <!-- focus -->
                                <Rectangle x:Name="FocusVisualWhite" Stroke="{ThemeResource FocusVisualWhiteStrokeThemeBrush}" StrokeDashOffset="1.5" Style="{StaticResource FocusVisual}" />
                                <Rectangle x:Name="FocusVisualBlack" Stroke="{ThemeResource FocusVisualBlackStrokeThemeBrush}" StrokeDashOffset="0.5" Style="{StaticResource FocusVisual}" />


                                <!-- text -->
                                <ContentPresenter x:Name="ContentPresenter"
                                                  Margin="{TemplateBinding Padding}"
                                                  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                                  AutomationProperties.AccessibilityView="Raw"
                                                  Content="{TemplateBinding Content}"
                                                  ContentTemplate="{TemplateBinding ContentTemplate}"
                                                  ContentTransitions="{TemplateBinding ContentTransitions}" />
                            </Grid>

                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="RadioButton" x:Key="ButtonRadioButtonStyleStepName"
               BasedOn="{StaticResource ButtonRadioButtonStyle}">
            <Setter Property="BorderBrush" Value="#FF0083"/>
            <Setter Property="Foreground" Value="#7F0041"/>
        </Style>

        <Style TargetType="RadioButton" x:Key="ButtonRadioButtonStyleNoteAccidental"
               BasedOn="{StaticResource ButtonRadioButtonStyle}">
            <Setter Property="BorderBrush" Value="#0CE825"/>
            <Setter Property="Foreground" Value="#056811"/>
        </Style>

        <Style TargetType="RadioButton" x:Key="ButtonRadioButtonStyleInterval"
               BasedOn="{StaticResource ButtonRadioButtonStyle}">
            <Setter Property="BorderBrush" Value="#3B0CE8"/>
            <Setter Property="Foreground" Value="#1B0568"/>
        </Style>

        <Style TargetType="RadioButton" x:Key="ButtonRadioButtonStyleIntervalInversion"
               BasedOn="{StaticResource ButtonRadioButtonStyle}">
            <Setter Property="BorderBrush" Value="#FFF10D"/>
            <Setter Property="Foreground" Value="#7F7806"/>
        </Style>

        <!-- Converters -->
        <converters:ToUpperConverter x:Key="ToUpperConverter" />
        <converters:AccidentalToBrushConverter x:Key="AccidentalToBrushConverter" />
    </Page.Resources>

    <Grid Background="{ThemeResource Brush-Blue}" x:Name="MainGrid">

        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup>
                <VisualState>
                    <VisualState.StateTriggers>
                        <!-- VisualState to be triggered when window
                         width is >=720 effective pixels. -->
                        <AdaptiveTrigger MinWindowWidth="720" />
                    </VisualState.StateTriggers>

                    <VisualState.Setters>
                        <Setter Target="PivotRight.Visibility"
                                Value="Visible" />
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>

        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition MinHeight="180"/>
                <RowDefinition Height="2*"/>
            </Grid.RowDefinitions>
            <StackPanel HorizontalAlignment="Stretch" Orientation="Vertical">
                <TextBlock FontSize="22" HorizontalAlignment="Center" FontWeight="SemiBold" Margin="20,50,20,20"
                           Foreground="{StaticResource Brush-White}">
                    <Run Text="{x:Bind ViewModel.Interval.Name, Mode=OneWay, Converter={StaticResource ToUpperConverter}}"/>
                </TextBlock>
                <TextBlock Margin="0,0,0,16" FontSize="36" HorizontalAlignment="Center" FontWeight="Bold"
                           Foreground="White">
                    <Run Text="{x:Bind ViewModel.Interval.StartingStep, Mode=OneWay}"/>
                    <Run Text="to"/>
                    <Run Text="{x:Bind ViewModel.Interval.EndingStep, Mode=OneWay}"
                         Foreground="{x:Bind ViewModel.Interval.EndingStep, Converter={StaticResource AccidentalToBrushConverter}, Mode=OneWay}"/>
                </TextBlock>
                <TextBlock HorizontalAlignment="Center"
                           Foreground="{StaticResource Brush-White}" FontSize="22">
                    <Run Text="{x:Bind ViewModel.Interval.Semitones, Mode=OneWay}"/>
                    <Run Text="semitones"/>
                </TextBlock>
            </StackPanel>
            <Grid Grid.Row="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="4*"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="6*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.ColumnSpan="2" Grid.RowSpan="2" Margin="12,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="6*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <RadioButton x:Name="RadioButtonNoteNameC" GroupName="NoteName" Content="C" Checked="{x:Bind ViewModel.NoteName_OnChecked}" Tag="{x:Bind ViewModel.StepNameC}" Grid.Column="0" Style="{StaticResource ButtonRadioButtonStyleStepName}"/>
                        <RadioButton GroupName="NoteName" Content="D" Checked="{x:Bind ViewModel.NoteName_OnChecked}" Tag="{x:Bind ViewModel.StepNameD}" Grid.Column="1" Style="{StaticResource ButtonRadioButtonStyleStepName}"/>
                        <RadioButton GroupName="NoteName" Content="E" Checked="{x:Bind ViewModel.NoteName_OnChecked}" Tag="{x:Bind ViewModel.StepNameE}" Grid.Column="2" Style="{StaticResource ButtonRadioButtonStyleStepName}"/>
                        <RadioButton GroupName="NoteName" Content="F" Checked="{x:Bind ViewModel.NoteName_OnChecked}" Tag="{x:Bind ViewModel.StepNameF}" Grid.Column="3" Style="{StaticResource ButtonRadioButtonStyleStepName}"/>
                        <RadioButton GroupName="NoteName" Content="G" Checked="{x:Bind ViewModel.NoteName_OnChecked}" Tag="{x:Bind ViewModel.StepNameG}" Grid.Column="4" Style="{StaticResource ButtonRadioButtonStyleStepName}"/>
                        <RadioButton GroupName="NoteName" Content="A" Checked="{x:Bind ViewModel.NoteName_OnChecked}" Tag="{x:Bind ViewModel.StepNameA}" Grid.Column="5" Style="{StaticResource ButtonRadioButtonStyleStepName}"/>
                        <RadioButton GroupName="NoteName" Content="B" Checked="{x:Bind ViewModel.NoteName_OnChecked}" Tag="{x:Bind ViewModel.StepNameB}" Grid.Column="6" Style="{StaticResource ButtonRadioButtonStyleStepName}"/>
                    </Grid>
                    <Grid Grid.Row="1" Grid.Column="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <RadioButton GroupName="NoteAccidental" Checked="{x:Bind ViewModel.NoteAccidental_OnChecked}" Tag="{x:Bind ViewModel.StepAccidentalDoubleFlat}" Content="♭♭" FontSize="26px" Style="{StaticResource ButtonRadioButtonStyleNoteAccidental}"/>
                        <RadioButton GroupName="NoteAccidental" Checked="{x:Bind ViewModel.NoteAccidental_OnChecked}" Tag="{x:Bind ViewModel.StepAccidentalFlat}" Content="♭" FontSize="26px" Grid.Column="1" Style="{StaticResource ButtonRadioButtonStyleNoteAccidental}"/>
                        <RadioButton x:Name="RadioButtonNoteAccidentalNatural" GroupName="NoteAccidental" Checked="{x:Bind ViewModel.NoteAccidental_OnChecked}" Tag="{x:Bind ViewModel.StepAccidentalNatural}" Content="♮" FontSize="26px" Grid.Column="2" Style="{StaticResource ButtonRadioButtonStyleNoteAccidental}"/>
                        <RadioButton GroupName="NoteAccidental" Checked="{x:Bind ViewModel.NoteAccidental_OnChecked}" Tag="{x:Bind ViewModel.StepAccidentalSharp}" Content="♯" FontSize="26px" Grid.Column="3" Style="{StaticResource ButtonRadioButtonStyleNoteAccidental}"/>
                        <RadioButton GroupName="NoteAccidental" Checked="{x:Bind ViewModel.NoteAccidental_OnChecked}" Tag="{x:Bind ViewModel.StepAccidentalDoubleSharp}" Content="♯♯" FontSize="26px" Grid.Column="4" Style="{StaticResource ButtonRadioButtonStyleNoteAccidental}"/>
                    </Grid>
                    <Grid Grid.Row="0" Grid.Column="1" Grid.RowSpan="2">
                        <Grid.RowDefinitions>
                            <RowDefinition />
                            <RowDefinition />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="7*"/>
                        </Grid.ColumnDefinitions>

                        <RadioButton x:Name="RadioButtonIntervalInversionUp"  GroupName="Inversion" Checked="{x:Bind ViewModel.IntervalInversionUp_OnChecked}" Grid.Column="1" Style="{StaticResource ButtonRadioButtonStyleIntervalInversion}">
                            <TextBlock Text="&#xE74A;" FontFamily="Segoe MDL2 Assets"/>
                        </RadioButton>
                        <RadioButton GroupName="Inversion" Checked="{x:Bind ViewModel.IntervalInversionDown_OnChecked}" Grid.Row="1" Grid.Column="1" Style="{StaticResource ButtonRadioButtonStyleIntervalInversion}">
                            <TextBlock Text="&#xE74B;" FontFamily="Segoe MDL2 Assets"/>
                        </RadioButton>
                    </Grid>
                </Grid>
                <Pivot Grid.Row="2" Grid.ColumnSpan="2">
                    <Pivot.HeaderTemplate>
                        <DataTemplate>
                            <Grid>
                                <TextBlock Text="{Binding}" FontSize="18" FontWeight="SemiBold" Margin="2,0,0,0" Foreground="White" />
                            </Grid>
                        </DataTemplate>
                    </Pivot.HeaderTemplate>
                    <PivotItem Header="SIMPLES">
                        <Grid Margin="0,0,0,10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <RadioButton Content="A2" GroupName="Interval" Checked="{x:Bind ViewModel.Interval_OnChecked}" Tag="{x:Bind ViewModel.IntervalA2}" Grid.Column="0" Grid.Row="0" Style="{StaticResource ButtonRadioButtonStyleInterval}"/>
                            <RadioButton Content="A3" GroupName="Interval" Checked="{x:Bind ViewModel.Interval_OnChecked}" Tag="{x:Bind ViewModel.IntervalA3}" Grid.Column="1" Grid.Row="0" Style="{StaticResource ButtonRadioButtonStyleInterval}"/>
                            <RadioButton Content="A4" GroupName="Interval" Checked="{x:Bind ViewModel.Interval_OnChecked}" Tag="{x:Bind ViewModel.IntervalA4}" Grid.Column="2" Grid.Row="0" Style="{StaticResource ButtonRadioButtonStyleInterval}"/>
                            <RadioButton Content="A5" GroupName="Interval" Checked="{x:Bind ViewModel.Interval_OnChecked}" Tag="{x:Bind ViewModel.IntervalA5}" Grid.Column="3" Grid.Row="0" Style="{StaticResource ButtonRadioButtonStyleInterval}"/>
                            <RadioButton Content="A6" GroupName="Interval" Checked="{x:Bind ViewModel.Interval_OnChecked}" Tag="{x:Bind ViewModel.IntervalA6}" Grid.Column="4" Grid.Row="0" Style="{StaticResource ButtonRadioButtonStyleInterval}"/>
                            <RadioButton Content="A7" GroupName="Interval" Checked="{x:Bind ViewModel.Interval_OnChecked}" Tag="{x:Bind ViewModel.IntervalA7}" Grid.Column="5" Grid.Row="0" Style="{StaticResource ButtonRadioButtonStyleInterval}"/>
                            <RadioButton Content="M2" GroupName="Interval" Checked="{x:Bind ViewModel.Interval_OnChecked}" Tag="{x:Bind ViewModel.IntervalM2}" Grid.Column="0" Grid.Row="1" Style="{StaticResource ButtonRadioButtonStyleInterval}"/>
                            <RadioButton Content="M3" GroupName="Interval" Checked="{x:Bind ViewModel.Interval_OnChecked}" Tag="{x:Bind ViewModel.IntervalM3}" Grid.Column="1" Grid.Row="1" Style="{StaticResource ButtonRadioButtonStyleInterval}"/>
                            <RadioButton Content="P4" GroupName="Interval" Checked="{x:Bind ViewModel.Interval_OnChecked}" Tag="{x:Bind ViewModel.IntervalP4}" Grid.Column="2" Grid.Row="1" Style="{StaticResource ButtonRadioButtonStyleInterval}"/>
                            <RadioButton x:Name="RadioButtonIntervalPerfectFifth" Content="P5" GroupName="Interval" Checked="{x:Bind ViewModel.Interval_OnChecked}" Tag="{x:Bind ViewModel.IntervalP5}" Grid.Column="3" Grid.Row="1" Style="{StaticResource ButtonRadioButtonStyleInterval}"/>
                            <RadioButton Content="M6" GroupName="Interval" Checked="{x:Bind ViewModel.Interval_OnChecked}" Tag="{x:Bind ViewModel.IntervalM6}" Grid.Column="4" Grid.Row="1" Style="{StaticResource ButtonRadioButtonStyleInterval}"/>
                            <RadioButton Content="M7" GroupName="Interval" Checked="{x:Bind ViewModel.Interval_OnChecked}" Tag="{x:Bind ViewModel.IntervalM7}" Grid.Column="5" Grid.Row="1" Style="{StaticResource ButtonRadioButtonStyleInterval}"/>
                            <RadioButton Content="P8" GroupName="Interval" Checked="{x:Bind ViewModel.Interval_OnChecked}" Tag="{x:Bind ViewModel.IntervalP8}" Grid.Column="6" Grid.Row="1" Style="{StaticResource ButtonRadioButtonStyleInterval}"/>
                            <RadioButton Content="m2" GroupName="Interval" Checked="{x:Bind ViewModel.Interval_OnChecked}" Tag="{x:Bind ViewModel.IntervalMin2}" Grid.Column="0" Grid.Row="2" Style="{StaticResource ButtonRadioButtonStyleInterval}"/>
                            <RadioButton Content="m3" GroupName="Interval" Checked="{x:Bind ViewModel.Interval_OnChecked}" Tag="{x:Bind ViewModel.IntervalMin3}" Grid.Column="1" Grid.Row="2" Style="{StaticResource ButtonRadioButtonStyleInterval}"/>
                            <RadioButton Content="m6" GroupName="Interval" Checked="{x:Bind ViewModel.Interval_OnChecked}" Tag="{x:Bind ViewModel.IntervalMin6}" Grid.Column="4" Grid.Row="2" Style="{StaticResource ButtonRadioButtonStyleInterval}"/>
                            <RadioButton Content="m7" GroupName="Interval" Checked="{x:Bind ViewModel.Interval_OnChecked}" Tag="{x:Bind ViewModel.IntervalMin7}" Grid.Column="5" Grid.Row="2" Style="{StaticResource ButtonRadioButtonStyleInterval}"/>
                            <RadioButton Content="d2" GroupName="Interval" Checked="{x:Bind ViewModel.Interval_OnChecked}" Tag="{x:Bind ViewModel.IntervalDim2}" Grid.Column="0" Grid.Row="3" Style="{StaticResource ButtonRadioButtonStyleInterval}"/>
                            <RadioButton Content="d3" GroupName="Interval" Checked="{x:Bind ViewModel.Interval_OnChecked}" Tag="{x:Bind ViewModel.IntervalDim3}" Grid.Column="1" Grid.Row="3" Style="{StaticResource ButtonRadioButtonStyleInterval}"/>
                            <RadioButton Content="d4" GroupName="Interval" Checked="{x:Bind ViewModel.Interval_OnChecked}" Tag="{x:Bind ViewModel.IntervalDim4}" Grid.Column="2" Grid.Row="3" Style="{StaticResource ButtonRadioButtonStyleInterval}"/>
                            <RadioButton Content="d5" GroupName="Interval" Checked="{x:Bind ViewModel.Interval_OnChecked}" Tag="{x:Bind ViewModel.IntervalDim5}" Grid.Column="3" Grid.Row="3" Style="{StaticResource ButtonRadioButtonStyleInterval}"/>
                            <RadioButton Content="d6" GroupName="Interval" Checked="{x:Bind ViewModel.Interval_OnChecked}" Tag="{x:Bind ViewModel.IntervalDim6}" Grid.Column="4" Grid.Row="3" Style="{StaticResource ButtonRadioButtonStyleInterval}"/>
                            <RadioButton Content="d7" GroupName="Interval" Checked="{x:Bind ViewModel.Interval_OnChecked}" Tag="{x:Bind ViewModel.IntervalDim7}" Grid.Column="5" Grid.Row="3" Style="{StaticResource ButtonRadioButtonStyleInterval}"/>
                            <RadioButton Content="d8" GroupName="Interval" Checked="{x:Bind ViewModel.Interval_OnChecked}" Tag="{x:Bind ViewModel.IntervalDim8}" Grid.Column="6" Grid.Row="3" Style="{StaticResource ButtonRadioButtonStyleInterval}"/>
                        </Grid>
                    </PivotItem>
                    <PivotItem Header="COMPOUNDS">
                        <Grid Margin="0,0,0,10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <RadioButton Content="A8" GroupName="Interval" Checked="{x:Bind ViewModel.Interval_OnChecked}" Tag="{x:Bind ViewModel.IntervalA8}" Grid.Column="0" Grid.Row="0" Style="{StaticResource ButtonRadioButtonStyleInterval}"/>
                            <RadioButton Content="A9" GroupName="Interval" Checked="{x:Bind ViewModel.Interval_OnChecked}" Tag="{x:Bind ViewModel.IntervalA9}" Grid.Column="1" Grid.Row="0" Style="{StaticResource ButtonRadioButtonStyleInterval}"/>
                            <RadioButton Content="A11" GroupName="Interval" Checked="{x:Bind ViewModel.Interval_OnChecked}" Tag="{x:Bind ViewModel.IntervalA11}" Grid.Column="3" Grid.Row="0" Style="{StaticResource ButtonRadioButtonStyleInterval}"/>
                            <RadioButton Content="A13" GroupName="Interval" Checked="{x:Bind ViewModel.Interval_OnChecked}" Tag="{x:Bind ViewModel.IntervalA13}" Grid.Column="5" Grid.Row="0" Style="{StaticResource ButtonRadioButtonStyleInterval}"/>
                            <RadioButton Content="M9" GroupName="Interval" Checked="{x:Bind ViewModel.Interval_OnChecked}" Tag="{x:Bind ViewModel.IntervalM9}" Grid.Column="1" Grid.Row="1" Style="{StaticResource ButtonRadioButtonStyleInterval}"/>
                            <RadioButton Content="M13" GroupName="Interval" Checked="{x:Bind ViewModel.Interval_OnChecked}" Tag="{x:Bind ViewModel.IntervalM13}" Grid.Column="5" Grid.Row="1" Style="{StaticResource ButtonRadioButtonStyleInterval}"/>
                            <RadioButton Content="P11" GroupName="Interval" Checked="{x:Bind ViewModel.Interval_OnChecked}" Tag="{x:Bind ViewModel.IntervalP11}" Grid.Column="3" Grid.Row="1" Style="{StaticResource ButtonRadioButtonStyleInterval}"/>
                            <RadioButton Content="m9" GroupName="Interval" Checked="{x:Bind ViewModel.Interval_OnChecked}" Tag="{x:Bind ViewModel.IntervalMin9}" Grid.Column="1" Grid.Row="2" Style="{StaticResource ButtonRadioButtonStyleInterval}"/>
                            <RadioButton Content="m13" GroupName="Interval" Checked="{x:Bind ViewModel.Interval_OnChecked}" Tag="{x:Bind ViewModel.IntervalMin13}" Grid.Column="5" Grid.Row="2" Style="{StaticResource ButtonRadioButtonStyleInterval}"/>
                            <RadioButton Content="d9" GroupName="Interval" Checked="{x:Bind ViewModel.Interval_OnChecked}" Tag="{x:Bind ViewModel.IntervalDim9}" Grid.Column="1" Grid.Row="3" Style="{StaticResource ButtonRadioButtonStyleInterval}"/>
                            <RadioButton Content="d11" GroupName="Interval" Checked="{x:Bind ViewModel.Interval_OnChecked}" Tag="{x:Bind ViewModel.IntervalDim11}" Grid.Column="3" Grid.Row="3" Style="{StaticResource ButtonRadioButtonStyleInterval}"/>
                            <RadioButton Content="d13" GroupName="Interval" Checked="{x:Bind ViewModel.Interval_OnChecked}" Tag="{x:Bind ViewModel.IntervalDim13}" Grid.Column="5" Grid.Row="3" Style="{StaticResource ButtonRadioButtonStyleInterval}"/>
                        </Grid>
                    </PivotItem>
                </Pivot>
            </Grid>
        </Grid>
        <Grid Grid.Column="1" BorderThickness="1,0,0,0" >
            <Grid.BorderBrush>
                <SolidColorBrush Color="{ThemeResource SystemChromeMediumLowColor}"/>
            </Grid.BorderBrush>
            <Pivot x:Name="PivotRight" Width="300" Visibility="Collapsed">
                <Pivot.HeaderTemplate>
                    <DataTemplate>
                        <Grid>
                            <TextBlock Text="{Binding}" FontSize="18" FontWeight="SemiBold" Foreground="White" />
                        </Grid>
                    </DataTemplate>
                </Pivot.HeaderTemplate>
                <PivotItem Header="Description">
                    <ScrollViewer Margin="0,0,-12,0">
                        <StackPanel>
                            <TextBlock Text="{x:Bind ViewModel.Interval.WikipediaDescription, Mode=OneWay}"
                                       TextWrapping="WrapWholeWords" TextAlignment="Left" Padding="0,0,20,20" FontSize="16">
                                <TextBlock.Foreground>
                                    <SolidColorBrush Color="{ThemeResource SystemChromeWhiteColor}"/>
                                </TextBlock.Foreground>
                            </TextBlock>
                            <HyperlinkButton NavigateUri="{x:Bind ViewModel.Interval.WikipediaUrl}" Content="Wikipédia" Foreground="#FF003340" />
                        </StackPanel>
                    </ScrollViewer>
                </PivotItem>
            </Pivot>
        </Grid>
    </Grid>
</Page>

