<Application
    x:Class="IntervalCalculator.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:IntervalCalculator"
    xmlns:viewModels="using:IntervalCalculator.ViewModels"
    RequestedTheme="Light">

    <Application.Resources>
        
        <!-- ViewModel Locator -->
        <viewModels:ViewModelLocator x:Key="Locator" />
        
        <!--  Colors  -->
        <Color x:Key="White">#FFFFFFFF</Color>
        <Color x:Key="Blue">#FF00CEFF</Color>
        
        <!--  Brushes  -->
        <SolidColorBrush x:Key="Brush-White" Color="{StaticResource White}" />
        <SolidColorBrush x:Key="Brush-Blue" Color="{StaticResource Blue}" />
        
    </Application.Resources>
</Application>
