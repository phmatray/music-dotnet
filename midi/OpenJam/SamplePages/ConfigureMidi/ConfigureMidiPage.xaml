<Page
    x:Class="OpenJam.SamplePages.ConfigureMidi.ConfigureMidiPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    DataContext="{Binding ConfigureMidiInstance, Source={StaticResource Locator}}">

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        
        
        
        
        
        

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120"/>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <TextBlock TextWrapping="Wrap" Text="Input" FontSize="24" Grid.Row="0" Grid.Column="1" />
        <ListBox x:Name="MidiInPortListBox" SelectionChanged="MidiInPortListBox_SelectionChanged" Grid.Row="1" Grid.Column="1" />
        <TextBlock TextWrapping="Wrap" Text="Output" FontSize="24" Grid.Column="2" />
        <ListBox x:Name="MidiOutPortListBox" SelectionChanged="MidiOutPortListBox_SelectionChanged" Grid.Row="1" Grid.Column="2"/>
        <TextBox x:Name="MidiInConsole" Grid.Row="3" TextWrapping="Wrap" Text="" Grid.Column="1" Grid.ColumnSpan="2"/>
        <Button Content="Send Midi" HorizontalAlignment="Stretch" Margin="10,10,10,0" Grid.Row="1" VerticalAlignment="Top" Click="SendMessageButton_Click"/>
        <TextBlock HorizontalAlignment="Left" Margin="27,102,0,0" Grid.Row="1" TextWrapping="Wrap" Text="{Binding Title}" VerticalAlignment="Top"/>
        <Button Content="Button" HorizontalAlignment="Left" Margin="10,173,0,0" Grid.Row="1" VerticalAlignment="Top" Command="{Binding GoToPlayPageCommand}"/>
    </Grid>
</Page>
